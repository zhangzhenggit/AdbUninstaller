<idea-plugin>
    <id>com.lenovo.tools.apppurge</id>
    <name>AppPurge</name>
    <vendor>Lenovo</vendor>

    <description><![CDATA[
    Scans all application modules in the current Android project, detects their installation
    status on connected ADB devices, and provides single or batch uninstall via a dialog.
    Handles pre-installed system APKs that become uninstallable after a debug overlay install.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.android</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="AppPurge" displayType="BALLOON" isLogByDefault="true"/>
    </extensions>

    <actions>
        <action id="com.lenovo.tools.apppurge.AdbUninstallerAction"
                class="com.lenovo.tools.apppurge.AdbUninstallerAction"
                text="AppPurge"
                description="Scan app modules and uninstall APKs from connected device via ADB"
                icon="/icons/apppurge.svg">
            <!-- New UI (Android Studio Panda / IntelliJ 2023.3+) toolbar center area -->
            <add-to-group group-id="MainToolbarCenter" anchor="last"/>
            <!-- Classic toolbar fallback -->
            <add-to-group group-id="MainToolBar" anchor="last"/>
            <!-- Tools menu -->
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
